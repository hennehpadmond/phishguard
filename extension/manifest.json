{
  "manifest_version": 3,
  "name": "PhishGuard — Real-Time Phishing Detector",
  "version": "1.0.0",
  "description": "Automatically detects phishing URLs as you browse. Powered by ML.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
  "https://phishguard-v0qq.onrender.com/*"
],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishGuard",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
